# Instagram Graph API (opcional - para carousel de posts no footer)
# Requer conta Instagram Business/Creator conectada a uma Meta App
# https://developers.facebook.com/docs/instagram-platform
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# TTL do cache em horas (padrão: 6). Atualiza posts a cada X horas.
INSTAGRAM_CACHE_TTL_HOURS=6
